{
  "name": "icon-view",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "tsc -b && vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "scan:icons": "tsx scripts/scan-icons.ts",
    "dev:watch": "concurrently \"npm run scan:icons -- --watch\" \"vite --config vite.config.ts\""
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.26.0",
    "@babel/types": "^7.26.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-xml": "^6.1.0",
    "@uiw/codemirror-theme-github": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "@vitejs/plugin-react": "^5.0.0",
    "chokidar": "^4.0.3",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "fast-glob": "^3.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-toastify": "^11.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "jsdom": "^26.0.0",
    "vitest": "^3.0.0"
  }
}
